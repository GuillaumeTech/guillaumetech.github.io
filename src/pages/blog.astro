<style>
	.page-content {
		padding: 64px 80px 80px;
	}

	/* ── TEXT GRID ───────────────────────────────────────── */
	.post-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		grid-auto-rows: 150px;
		gap: 48px 48px;
	}

	.post-cell {
		display: flex;
		flex-direction: column;
		gap: 5px;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.post-cell p {
		font-size: 0.9rem;
		line-height: 1.75;
		color: #2a2a2a;
		display: -webkit-box;
		-webkit-line-clamp: 5;
		-webkit-box-orient: vertical;  
  overflow: hidden;

	}

	/* ── RESPONSIVE ──────────────────────────────────────── */
	@media (max-width: 900px) {
		.page-content {
			padding: 40px 24px 60px;
		}

		.text-grid {
			grid-template-columns: 1fr;
			gap: 32px 0;
		}
	}

	@media (max-width: 600px) {
		.page-content {
			padding: 32px 16px 48px;
		}
	}
</style>
