<style>
  .post-cell {
    display: flex;
    flex-direction: column;
    gap: 5px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .separator {
    font-family: "Young Serif", Georgia, serif;
    flex-direction: row;
    display: flex;
    gap: 1rem;
    align-items: center;
    hr {
      width: 100%;
      height: 1px;
    }
  }

    @media (max-width: 1000px) {
    .separator {
      padding: 2rem 0;
    }
  }

  .post-cell p {
    font-size: 0.9rem;
    line-height: 1.75;
    color: #2a2a2a;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

</style>
