---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { Image } from "astro-lqip/components";
import "@fancyapps/ui/dist/fancybox/fancybox.css";
import car from "../assets/car.jpg";
import tree from "../assets/tree.jpg";
import building from "../assets/building.jpg";
import Grid from "../components/Grid.astro";
---

<Layout>
  <Header greeting="Photos, and other visual venture" />

  <main class="page-content">
    <Grid>
      <div class="post-cell span-w-2">
        <h4>Lorem Ipsum</h4>
        <p>
          Losrem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad
          minim veniam, quis nostrud exercitation ullamco laboris nisi ut
          aliquip ex ea commodo consequat. Duis aute irure dolor in
          reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla
          pariatur. Excepteur sint occaecat cupidatat non proident, sunt in
          culpa qui officia deserunt mollit anim id est laborum
        </p>
      </div>

      <a
        style={`--width: ${car.width}; --height: ${car.height};`}
        href={car.src}
        target="_blank"
        data-fancybox
        class="post-cell"
      >
        <Image src={car} alt="A description of my image."  loading={"eager"} />
      </a>
      <a
        style={`--width: ${tree.width}; --height: ${tree.height};`}
        href={tree.src}
        target="_blank"
        data-fancybox
        class="post-cell"
      >
        <Image src={tree} alt="A description of my image."  loading={"eager"}/>
      </a>
      <a
        style={`--width: ${building.width}; --height: ${building.height};`}
        href={building.src}
        target="_blank"
        data-fancybox
        class="post-cell"
      >
        <Image src={building} alt="A description of my image." loading={"eager"}/>
      </a>

      <div class="post-cell">
        <Image src={car} alt="A description of my image." />
      </div>
      <div class="post-cell span-w-2 span-h-2">
        <Image src={car} alt="A description of my image." />
      </div><div class="post-cell">
        <Image src={car} alt="A description of my image." />
      </div><div class="post-cell">
        <Image src={car} alt="A description of my image." />
      </div>
      <div class="post-cell span-h-2">
        <h4>Lorem Ipsum</h4>
        <p class="long">
          Losrem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad
          minim veniam, quis nostrud exercitation ullamco laboris nisi ut
          aliquip ex ea commodo consequat. Duis aute irure dolor in
          reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla
          pariatur. Excepteur sint occaecat cupidatat non proident, sunt in
          culpa qui officia deserunt mollit anim id est laborum
        </p>
      </div>
      <div class="post-cell">
        <Image src={car} alt="A description of my image." />
      </div>
      <div class="post-cell">
        <Image src={car} alt="A description of my image." />
      </div>
      <div class="post-cell">
        <Image src={car} alt="A description of my image." />
      </div>
    </Grid>
  </main>
</Layout>

<script>
  import { Fancybox } from "@fancyapps/ui/dist/fancybox/";

  Fancybox.bind("[data-fancybox]", {
    theme: "auto",
    mainStyle: {
      "--f-button-width": "44px",
      "--f-button-height": "44px",
      "--f-toolbar-padding": "16px",
    },
    Carousel: {
      Arrows: false,
      Toolbar: {
        display: {
          left: [],
          middle: [],
          right: ["close"],
        },
      },
    },
  });
</script>

<style>
	

 

  .post-cell {
    display: flex;
    flex-direction: column;
    gap: 5px;
    overflow: hidden;
    text-overflow: ellipsis;
    &.span-w-2 {
      grid-column: span 2;
    }
    &.span-h-2 {
      grid-row: span 2;
    }
  }

  .post-cell :global([data-astro-lqip]) {
    width: 100%;
    height: 100%;
  }

  .post-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-cell p {
    font-size: 0.9rem;
    line-height: 1.75;
    color: #2a2a2a;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-cell p.long {
    font-size: 0.9rem;
    line-height: 1.75;
    color: #2a2a2a;
    display: -webkit-box;
    -webkit-line-clamp: 20;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }


</style>
