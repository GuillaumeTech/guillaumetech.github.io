</Layout>

<script>
  import { Fancybox } from "@fancyapps/ui/dist/fancybox/";

  Fancybox.bind("[data-fancybox]", {
    theme: "auto",
    mainStyle: {
      "--f-button-width": "44px",
      "--f-button-height": "44px",
      "--f-toolbar-padding": "16px",
    },
    Carousel: {
      Arrows: false,
      Toolbar: {
        display: {
          left: [],
          middle: [],
          right: ["close"],
        },
      },
    },
  });
</script>

<style>
  /* astro-lqip: keep the blurry overlay ON TOP of the img while it streams in.
	   The img has z-index:1; the ::after starts at --z-index (0 by default).
	   Setting it to 2 means the placeholder covers the partially-decoded image.
	   Once onload fires, astro-lqip resets --z-index to 1 and --opacity to 0. */
  :global([data-astro-lqip]) {
    --z-index: 2;
    width: 100%;
    height: 100%;
  }

  :global([data-astro-lqip]::after) {
    filter: blur(10px);
    transform: scale(1.2);
  }

  :global(body) {
    --background-color: #fffbd2;
    --accent-color: var(--accent-color-photography);
  }
</style>
