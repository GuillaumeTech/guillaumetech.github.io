---
import Nav from './Nav.astro';

interface Props {
	greeting: string;
}

const { greeting } = Astro.props;
---

<header class="site-header">
	<div class="logo">
		<a href="/" class="logo-name">Guillaume Técher</a>
	</div>

	<Nav />

	<div class="greeting" aria-label="Greeting">
		<h1 class="greeting-text">{greeting}</h1>
	</div>
</header>

<style>
	/* ── HEADER GRID ──────────────────────────────────────
	   Rows: [logo] [nav] [greeting]
	   The greeting is pushed to the bottom-right via grid.
	──────────────────────────────────────────────────────── */
	.site-header {
			padding-bottom: 32px;

		display: grid;
		grid-template-columns: 1fr 2fr;
		grid-template-rows: auto 1fr;
		grid-template-areas:
			"logo     ."
			"nav      greeting";
	}

	/* ── LOGO ─────────────────────────────────────────────── */
	.logo {
		grid-area: logo;
		padding-bottom: 20px;
		padding-top: 40px;
	}

	.logo-name {
				font-family: 'Young Serif', Georgia, serif;

		font-size: 1.5rem;
		font-weight: 600;
		color: #1a1a1a;
		text-decoration: none;
	}

	/* ── NAV ──────────────────────────────────────────────── */
	:global(.site-header .nav) {
		grid-area: nav;
	}

	/* ── GREETING ─────────────────────────────────────────── */
	.greeting {
		grid-area: greeting;
		display: flex;
		align-items: flex-end;
		justify-content: flex-end;
	}

	.greeting-text {
		font-family: 'Young Serif', Georgia, serif;
		font-size: 2rem;
		font-weight: 700;
	}

	/* ── RESPONSIVE ───────────────────────────────────────── */
	@media (max-width: 1000px) {
		.site-header {
			grid-template-columns: 1fr;
			grid-template-rows: auto auto auto;
			grid-template-areas:
				"logo"
				"nav"
				"greeting";
			min-height: unset;
		}

		.greeting {
			justify-content: flex-start;
			padding-top: 32px;

		}

		.greeting-text {
			font-size: 1.7rem;
		}
	}

	@media (max-width: 600px) {
		.site-header {
			padding: 24px 0;
		}

		.logo-name {
			font-size: 1.4rem;
		}

		.logo {
		padding-top: 20px;
	}

		.greeting-text {
			font-size: 1.5rem;
		}
	}
</style>
