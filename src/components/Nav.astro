---
const pathname = Astro.url.pathname;

const links = [
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/photography", label: "Photography & other mediums" },
  { href: "/blog", label: "Blog" },
//   TODO: { href: "/resume", label: "Resume" },
];
---

<nav class="nav" aria-label="Main navigation">
  {links.map(({ href, label }) => {
    const isActive = pathname === href || pathname.startsWith(href + "/");
    return (
      <a
        href={href}
        class:list={["nav-link", { active: isActive }]}
        aria-current={isActive ? "page" : undefined}
      >
        {label}
      </a>
    );
  })}

</nav>

<style>
  .nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 8px;
    grid-area: nav;
  }

  .nav-link {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--primary-text-color);
    padding: 10px 0;
    position: relative;
  }

  .nav-link:hover::before,
  .nav-link.active::before {
    content: "";
    position: absolute;
    bottom: 8px;
    left: -20px;
    width: 12px;
    height: 1.7rem;
  }

  .nav-link:nth-child(1):hover::before,
  .nav-link:nth-child(1).active::before {
    background-color: var(--accent-color-about);
  }
  .nav-link:nth-child(2):hover::before,
  .nav-link:nth-child(2).active::before {
    background-color: var(--accent-color-projects);
  }
  .nav-link:nth-child(3):hover::before,
  .nav-link:nth-child(3).active::before {
    background-color: var(--accent-color-photography);
  }
  .nav-link:nth-child(4):hover::before,
  .nav-link:nth-child(4).active::before {
    background-color: var(--accent-color-blog);
  }
</style>
