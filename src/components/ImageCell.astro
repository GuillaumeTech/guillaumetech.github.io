---
import type { ImageMetadata } from "astro";
import { Image } from "astro-lqip/components";

import Cell from "../components/Cell.astro";

interface Props {
  imageName: string;
  spanH?: number;
  spanV?: number;
  alt: string;
  loading: "eager" | "lazy";
}

const { imageName, spanH = 1, spanV = 1, alt, loading } = Astro.props;
const imagePath = `/src/assets/${imageName}.jpg`;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/*.jpg",
);
if (!images[imagePath])
  throw new Error(`"${imagePath}" does not exist in glob: "src/assets/*.jpg"`);

const { default: image } = await images[imagePath]();
---

<Cell width={spanH} height={spanV}>
  <a
    style={`--width: ${image.width}; --height: ${image.height};`}
    href={image.src}
    target="_blank"
    data-fancybox
  >
    <Image src={image} alt={alt} loading={loading} />
  </a>

  <style>
    a img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  </style>
</Cell>
