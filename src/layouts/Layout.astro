<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    width: 100%;
    min-height: 100%;
    color: #1a1a1a;
    font-family: "Inter", sans-serif;
  }

  .layout-container {
    max-width: 1200px;
    margin: auto;
    padding: 0 80px;
  }

  @media (max-width: 1200px) {
    .layout-container {
      max-width: 1000px;
      margin: auto;
      padding: 0 60px;
    }
  }

   @media (max-width: 600px) {
    .layout-container {
      padding: 0 30px;
    }
  }

  /* astro-lqip: keep the blurry overlay ON TOP of the img while it streams in.
	   The img has z-index:1; the ::after starts at --z-index (0 by default).
	   Setting it to 2 means the placeholder covers the partially-decoded image.
	   Once onload fires, astro-lqip resets --z-index to 1 and --opacity to 0. */
  [data-astro-lqip] {
    --z-index: 2;
	width: 100%;
    height: 100%;
  }

  [data-astro-lqip]::after {
    filter: blur(10px);
    transform: scale(1.2);
  }
</style>
